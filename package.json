{
  "name": "nuxt-seo-utils",
  "type": "module",
  "version": "8.3.1",
  "packageManager": "pnpm@11.5.3",
  "description": "SEO utilities to improve your Nuxt sites discoverability and shareability",
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://nuxtseo.com/docs/seo-utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/nuxt-seo-utils.git"
  },
  "bugs": {
    "url": "https://github.com/harlan-zw/nuxt-seo-utils/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "bin": {
    "nuxt-seo-utils": "./bin/nuxt-seo-utils.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "build": {
    "externals": [
      "unhead",
      "@unhead/vue",
      "@unhead/vue/plugins",
      "@unhead/vue/utils",
      "@unhead/vue/vite",
      "@unhead/bundler/vite"
    ]
  },
  "scripts": {
    "client:build": "node -e \"require('fs').cpSync('devtools','dist/devtools',{recursive:true})\"",
    "build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && npm run client:build",
    "dev": "nuxt dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground && pnpm prepare:fixtures && pnpm run client:build",
    "stub": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "prepare:fixtures": "nuxt prepare test/fixtures/basic && nuxt prepare test/fixtures/i18n && nuxt prepare test/fixtures/csp",
    "test": "vitest",
    "test:run": "vitest run --exclude '**/\\_\\_runtime\\_\\_/**'",
    "test:runtime": "cd test/fixtures/basic && vitest --run",
    "prepack": "pnpm run build",
    "release": "pnpm build && bumpp -x \"npx changelogen --output=CHANGELOG.md\"",
    "lint:docs": "markdownlint ./docs/content && case-police 'docs/content/**/*.md' *.md",
    "lint:docs:fix": "markdownlint ./docs/content --fix && case-police 'docs/content/**/*.md' *.md --fix",
    "test:compat-v2": "node test/compat-v2/run.mjs"
  },
  "peerDependencies": {
    "@unhead/vue": "^2.0.7 || ^3.0.0",
    "esbuild": ">=0.17.0",
    "lightningcss": ">=1.20.0",
    "nuxt": "^3.0.0 || ^4.0.0",
    "rolldown": ">=1.0.0-beta.0",
    "unhead": "^2.0.7 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "@unhead/vue": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "lightningcss": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "unhead": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "@unhead/bundler": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:",
    "defu": "catalog:",
    "escape-string-regexp": "catalog:",
    "exsolve": "catalog:",
    "image-size": "catalog:",
    "nuxt-site-config": "catalog:",
    "nuxtseo-shared": "catalog:",
    "pathe": "catalog:",
    "pkg-types": "catalog:",
    "scule": "catalog:",
    "tinyglobby": "catalog:",
    "ufo": "catalog:"
  },
  "optionalDependencies": {
    "sharp": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@nuxt/devtools-kit": "catalog:",
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@nuxt/ui": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@types/node": "catalog:",
    "@unhead/vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "bumpp": "catalog:",
    "case-police": "catalog:",
    "cheerio": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-harlanzw": "catalog:",
    "happy-dom": "catalog:",
    "lint-staged": "catalog:",
    "markdownlint-cli": "catalog:",
    "nuxt": "catalog:",
    "nuxt-security": "catalog:",
    "nuxtseo-layer-devtools": "catalog:",
    "playwright-core": "catalog:",
    "sass": "catalog:",
    "semver": "catalog:",
    "sirv": "catalog:",
    "typescript": "catalog:",
    "ultrahtml": "catalog:",
    "unbuild": "catalog:",
    "unhead": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
